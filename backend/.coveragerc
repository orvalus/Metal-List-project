[run]
# Coverage configuration for Metal List backend
source = .
omit =
    */venv/*
    */site-packages/*
    test_*.py
    */tests/*

[report]
# Coverage report settings
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod

precision = 2
skip_covered = False
skip_empty = True

[html]
directory = htmlcov
